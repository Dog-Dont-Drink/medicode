# 基础配置
APP_ENV=development
APP_PORT=8000
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30
JWT_REFRESH_EXPIRE_DAYS=90

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# Supabase Storage
STORAGE_BUCKET=medicode-files
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-jwt

# 支付宝当面付
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-merchant-private-key-base64-or-pem
ALIPAY_PUBLIC_KEY=your-alipay-public-key-base64-or-pem
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/notify
ALIPAY_SANDBOX=true

# SMTP
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
